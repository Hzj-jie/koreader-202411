msgstr "Stel standaard verbergen van niet-lineaire fragmenten in op %1?"

#: frontend/apps/reader/modules/readerrolling.lua:501
#: plugins/simpleui.koplugin/sui_menu.lua:1137
#: plugins/simpleui.koplugin/sui_menu.lua:1515
