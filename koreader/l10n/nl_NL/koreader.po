msgid "Regular"
msgstr "Normaal"

#: frontend/ui/data/creoptions.lua:26
msgctxt "Font weight class"
msgid "Medium"
msgstr "Middel"

#: frontend/ui/data/creoptions.lua:27
msgctxt "Font weight class"
msgid "Semi-bold"
msgstr "Halfvet"

#: frontend/ui/data/creoptions.lua:28
msgctxt "Font weight class"
msgid "Bold"
msgstr "Vet"

#: frontend/ui/data/creoptions.lua:29
msgctxt "Font weight class"
msgid "Extra-bold"
msgstr "Extra vet"

#: frontend/ui/data/creoptions.lua:30
