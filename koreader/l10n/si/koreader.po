#: frontend/ui/data/creoptions.lua:340
msgid "Render Mode"
msgstr ""

#: frontend/ui/data/creoptions.lua:342
msgid "legacy"
msgstr ""

#: frontend/ui/data/creoptions.lua:343
msgid "flat"
msgstr ""

#: frontend/ui/data/creoptions.lua:344
msgid "book"
msgstr ""

#: frontend/ui/data/creoptions.lua:345
msgid "web"
msgstr ""

#: frontend/ui/data/creoptions.lua:353
msgid ""
"- 'legacy' uses original CR3 block rendering code.\n"
"- 'flat' ensures flat rendering with collapsing margins and accurate page "
"breaks.\n"
"- 'book' additionally allows floats, but limits style support to avoid blank "
"spaces and overflows.\n"
"- 'web' renders as web browsers do, allowing negative margins and possible "
"page overflow."
msgstr ""

#: frontend/ui/data/creoptions.lua:362
msgid "Zoom (dpi)"
