msgid "In-page footnotes"
msgstr ""

#: frontend/ui/data/css_tweaks.lua:919 frontend/ui/data/css_tweaks.lua:922
msgid "In-page FB2 footnotes"
msgstr ""

#: frontend/ui/data/css_tweaks.lua:924
msgid ""
"Show FB2 footnote text at the bottom of pages that contain links to them."
msgstr ""

#: frontend/ui/data/css_tweaks.lua:950
msgid "In-page FB2 endnotes"
msgstr ""

#: frontend/ui/data/css_tweaks.lua:952
msgid ""
"Show FB2 endnote text at the bottom of pages that contain links to them."
msgstr ""

#: frontend/ui/data/css_tweaks.lua:975
msgid "Keep regular font size"
msgstr ""

#: frontend/ui/data/css_tweaks.lua:977
msgid ""
"FB2 footnotes and endnotes get a smaller font size when displayed in-page. "
"This allows them to be shown with the normal font size."
msgstr ""

#: frontend/ui/data/css_tweaks.lua:999
msgid "In-page EPUB footnotes"
msgstr ""

#: frontend/ui/data/css_tweaks.lua:1001 frontend/ui/data/css_tweaks.lua:1032
msgid ""
"Show EPUB footnote text at the bottom of pages that contain links to them.\n"
"This only works with footnotes that have specific attributes set by the "
"publisher."
msgstr ""

#: frontend/ui/data/css_tweaks.lua:1030
msgid "In-page EPUB footnotes (smaller)"
msgstr ""

#: frontend/ui/data/css_tweaks.lua:1064
msgid "In-page Wikipedia footnotes"
msgstr ""

#: frontend/ui/data/css_tweaks.lua:1066 frontend/ui/data/css_tweaks.lua:1089
msgid "Show footnotes at the bottom of pages in Wikipedia EPUBs."
msgstr ""

#: frontend/ui/data/css_tweaks.lua:1087
msgid "In-page Wikipedia footnotes (smaller)"
msgstr ""

#: frontend/ui/data/css_tweaks.lua:1115
msgid "In-page classic classname footnotes"
msgstr ""

#: frontend/ui/data/css_tweaks.lua:1117 frontend/ui/data/css_tweaks.lua:1145
msgid ""
"Show footnotes with classic classnames at the bottom of pages.\n"
"This tweak can be duplicated as a user style tweak when books contain "
"footnotes wrapped with other class names."
msgstr ""

#: frontend/ui/data/css_tweaks.lua:1143
msgid "In-page classic classname footnotes (smaller)"
msgstr ""

