msgid "none"
msgstr "無"

#: frontend/ui/data/koptoptions.lua:104
msgctxt "Page crop"
msgid "auto"
msgstr "自動"

#: frontend/ui/data/koptoptions.lua:105
msgctxt "Page crop"
