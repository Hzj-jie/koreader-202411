msgstr ""

#: frontend/ui/elements/refresh_menu_table.lua:32
msgid "Low full refresh rate for better responsiveness"
msgstr ""

#: frontend/ui/elements/refresh_menu_table.lua:42
msgid "Balance between responsiveness and quality"
