msgid_plural "Speed-up rate interval: %1 seconds"
msgstr[0] "Intervalle d'accélération (%1 seconde)"
msgstr[1] "Intervalle d'accélération (%1 secondes)"

#: frontend/apps/reader/modules/readerhighlight.lua:1012
msgid "Time interval"
msgstr "Intervalle de temps"

#: frontend/apps/reader/modules/readerhighlight.lua:1014
msgid ""
"Select a decimal value up to 1 second. This is the period of time within "
"which multiple keystrokes will speed-up rate of travel."
msgstr ""
"Sélectionnez une valeur décimale allant jusqu'à 1 seconde. C'est la période "
"pendant laquelle plusieurs frappes vont augmenter la vitesse de déplacement."

