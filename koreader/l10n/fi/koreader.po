#: frontend/apps/reader/modules/readerstyletweak.lua:893
msgid "Matching elements"
msgstr ""

#: frontend/apps/reader/modules/readerstyletweak.lua:897
msgid ""
"p.className matches a <p> with class='className'.\n"
"\n"
"*.className matches any element with class='className'.\n"
"\n"
"p:not([class]) matches a <p> without any class= attribute."
msgstr ""
"p.className vastaa arvoa <p> ja class='className'.\n"
"\n"
"*.className vastaa mitä tahansa elementtiä, jossa on class='className'.\n"
"\n"
"p:not([luokka]) vastaa <p>-arvoa ilman class=-attribuuttia."

#: frontend/apps/reader/modules/readerstyletweak.lua:907
msgid ""
"aside > p matches a <p> children of an <aside> element.\n"
"\n"
"aside p (without any intermediate symbol) matches a <p> descendant of an "
"<aside> element."
msgstr ""

#: frontend/apps/reader/modules/readerstyletweak.lua:915
msgid ""
"p + img matches a <img> if its immediate previous sibling is a <p>.\n"
"\n"
"p ~ img matches a <img> if any of its previous siblings is a <p>."
msgstr ""

#: frontend/apps/reader/modules/readerstyletweak.lua:924
msgid ""
"[name=\"what\"] matches if the element has the attribute 'name' and its "
"value is exactly 'what'.\n"
"\n"
"[name] matches if the attribute 'name' is present.\n"
"\n"
"[name~=\"what\"] matches if the value of the attribute 'name' contains "
"'what' as a word (among other words separated by spaces)."
msgstr ""
"[name=\"what\"] vastaa, jos elementillä on attribuutti \"name\" ja sen arvo "
"on täsmälleen \"what\".\n"
"\n"
"[name] vastaa, jos attribuutti 'name' on olemassa.\n"
"\n"
"[name~=\"what\"] vastaa, jos attribuutin 'name' arvo sisältää sanan 'what' "
"(muun muassa välilyönnillä erotettuina)."

#: frontend/apps/reader/modules/readerstyletweak.lua:935
msgid ""
"[name*=\"what\" i] matches any element having the attribute 'name' with a "
"value that contains 'what', case insensitive.\n"
"\n"
"[name^=\"what\"] matches if the attribute value starts with 'what'.\n"
"\n"
"[name$=\"what\"] matches if the attribute value ends with 'what'."
msgstr ""

#: frontend/apps/reader/modules/readerstyletweak.lua:945
msgid ""
"Similar in syntax to attribute matching, but matches the inner text of an "
"element.\n"
"\n"
"p[_=\"what\"] matches any <p> whose text is exactly 'what'.\n"
"\n"
"p[_] matches any non-empty <p>.\n"
"\n"
"p:not([_]) matches any empty <p>.\n"
"\n"
"p[_~=\"what\"] matches any <p> that contains the word 'what'."
msgstr ""

#: frontend/apps/reader/modules/readerstyletweak.lua:959
msgid ""
"Similar in syntax to attribute matching, but matches the inner text of an "
"element.\n"
"\n"
"p[_*=\"what\" i] matches any <p> that contains 'what', case insensitive.\n"
"\n"
"p[_^=\"what\"] matches any <p> whose text starts with 'what'.\n"
"(This can be used to match \"Act\" or \"Scene\", or character names in "
"plays, and make them stand out.)\n"
"\n"
"p[_$=\"what\"] matches any <p> whose text ends with 'what'."
msgstr ""

#: frontend/apps/reader/modules/readerstyletweak.lua:972
msgid ""
"p:first-child matches a <p> that is the first child of its parent.\n"
"\n"
"p:last-child matches a <p> that is the last child of its parent.\n"
"\n"
"p:nth-child(odd) matches any other <p> in a series of sibling <p>."
msgstr ""

#: frontend/apps/reader/modules/readerstyletweak.lua:982
msgid ""
"On a book page, select some text spanning around (before and after) the "
